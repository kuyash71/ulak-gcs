# --- IDEs ---
.vscode/
.idea/
*.iml
*.iws
*.suo
*.user
*.userosscache
*.sln.docstates

# --- Logs & runtime data ---
*.log
logs/
*.trace
*.tmp
*.bak

# --- Python/venv ---
.venv/
venv/
__pycache__/
*.pyc

# --- Docs temp ---
docs/tmp/
docs/tmp/**

# --- Other temp / cache ---
.cache/
tmp/
